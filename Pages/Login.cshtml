@page
@model StudentComplaintSystem.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>

.login-wrapper{
    min-height:80vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

.login-card{
    width:420px;
    background:white;
    padding:30px;
    border-radius:12px;
    border:1px solid #e6e6e6;
    box-shadow:0 4px 15px rgba(0,0,0,0.06);
}

.login-title{
    text-align:center;
    margin-bottom:25px;
    font-weight:600;
}

.form-group{
    margin-bottom:18px;
}

label{
    display:block;
    font-weight:500;
    margin-bottom:6px;
}

input{
    width:100%;
    padding:12px;
    border-radius:8px;
    border:1px solid #dcdcdc;
    font-size:14px;
}

input:focus{
    outline:none;
    border-color:#0d6efd;
    box-shadow:0 0 0 2px rgba(13,110,253,0.15);
}

.btn-login{
    width:100%;
    background:#0d6efd;
    color:white;
    border:none;
    padding:12px;
    border-radius:8px;
    font-weight:600;
    cursor:pointer;
    transition:0.2s ease;
}

.btn-login:hover{
    background:#0b5ed7;
}

</style>

<div class="login-wrapper">

    <div class="login-card">

        <div class="login-title">
            Student Complaint System
        </div>

        <form method="post">

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required />
            </div>

            <button type="submit" class="btn-login">
                Login
            </button>

        </form>

    </div>

</div>