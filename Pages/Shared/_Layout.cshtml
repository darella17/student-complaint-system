<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Lead City Complaint Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>

        body{
            background:#f7f6f3;
            font-family: "Segoe UI", sans-serif;
            margin:0;
        }

        /* HEADER */
        .portal-header{
            background: linear-gradient(135deg,#0d2b6b,#3a6ed8);
            color:white;
            padding:15px 30px;
        }

        .portal-header h4{
            margin:0;
            font-weight:600;
        }

        /* WRAPPER */
        .layout{
            display:flex;
        }

        /* SIDEBAR */
        .sidebar{
            width:230px;
            background:white;
            min-height:100vh;
            border-right:1px solid #ddd;
            padding-top:20px;
        }

        .sidebar a{
            display:block;
            padding:12px 20px;
            text-decoration:none;
            color:#333;
            font-weight:500;
        }

        .sidebar a:hover{
            background:#e8f0ff;
            color:#0d2b6b;
        }

        /* MAIN CONTENT */
        .main-content{
            flex:1;
            padding:30px;
        }

        /* STATUS BAR */
        .status-bar{
            background:#e7efff;
            border-left:5px solid #3a6ed8;
            padding:15px;
            border-radius:6px;
            margin-bottom:20px;
        }

        table{
            background:white;
        }

    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="portal-header d-flex justify-content-between align-items-center">

        <h4>Lead City University, Ibadan</h4>

        <div>
            🔔 👤
        </div>

    </div>

    <!-- BODY LAYOUT -->
    <div class="layout">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <a href="/StudentDashboard">Student Dashboard</a>

            <a href="/SubmitComplaint">Submit Complaint</a>

            <a href="/AdminDashboard">Admin Dashboard</a>

            

        </div>

        <!-- MAIN CONTENT -->
        <div class="main-content">
            @RenderBody()
        </div>

    </div>

</body>
</html>