@page
@model StudentComplaintSystem.Pages.StudentDashboardModel

@{
    ViewData["Title"] = "Student Dashboard";
}

<style>

.main-content{
    width:100%;
}

.header-bar{
    background:linear-gradient(90deg,#0d6efd,#3a8bfd);
    color:white;
    padding:20px;
    border-radius:8px;
    margin-bottom:20px;
}

.profile-card{
    background:white;
    border:1px solid #ddd;
    border-radius:8px;
    padding:20px 25px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:20px;
}

.profile-info h5{
    margin:0;
}

.profile-photo{
    width:80px;
    height:80px;
    border-radius:50%;
    object-fit:cover;
    border:2px solid #ccc;
    background:#ddd;
}

.status-bar{
    margin-top:20px;
    background:#e8f0ff;
    padding:15px;
    border-radius:8px;
    overflow-x:auto;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:10px;
}

th, td{
    padding:10px;
    border-bottom:1px solid #ddd;
    text-align:left;
    font-size:14px;
}

th{
    background:#f5f5f5;
}

</style>

<div class="main-content">

    <div class="header-bar">
        <h3>Lead City University, Ibadan</h3>
        <p>Student Complaint and Feedback Portal</p>
    </div>

    <div class="profile-card">

        <div class="profile-info">
            <h5>Student Dashboard</h5>
            <p>Welcome to your dashboard</p>
        </div>

        <img src="~/images/leadcity-university.png" class="profile-photo" />

    </div>

    <div class="status-bar">

        <h4>Your Complaints</h4>

        <table>
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Matric Number</th>
                    <th>Level</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Date Submitted</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Complaints)
                {
                    <tr>
                        <td>@item.StudentName</td>
                        <td>@item.MatricNumber</td>
                        <td>@item.Level</td>
                        <td>@item.Title</td>
                        <td>@item.Description</td>
                        <td>@item.Status</td>
                        <td>@item.DateSubmitted</td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>