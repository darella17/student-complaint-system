@page
@model StudentComplaintSystem.Pages.StudentDashboardModel
@{
    ViewData["Title"] = "Student Dashboard";
}

<style>

.main-content{
    width:100%;
}

.header-bar{
    background:linear-gradient(90deg,#0d6efd,#3a8bfd);
    color:white;
    padding:20px;
    border-radius:8px;
    margin-bottom:20px;
}

.profile-card{
    background:white;
    border:1px solid #ddd;
    border-radius:8px;
    padding:20px 25px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:20px;
}

.profile-info h5{
    margin:0;
}

.profile-photo{
    width:80px;
    height:80px;
    border-radius:50%;
    object-fit:cover;
    border:2px solid #ccc;
    background:#ddd;
}
}

.status-bar{
    margin-top:20px;
    background:#e8f0ff;
    padding:15px;
    border-radius:8px;
}

</style>

<div class="main-content">

    <div class="header-bar">
        <h3>Lead City University, Ibadan</h3>
        <p>Student Complaint and Feedback Portal</p>
    </div>

    <div class="profile-card">

        <div class="profile-info">
            <h5>Student</h5>
            <p>Welcome to your dashboard</p>
        </div>

        <img src="~/images/leadcity-university.png" class="profile-photo" />

    </div>



</div>